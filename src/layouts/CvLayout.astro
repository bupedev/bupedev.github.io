---
import { getCollection } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import { site } from "../data/site";

const { frontmatter } = Astro.props;
const entries = await getCollection("cv");

const sortEntries = (a: (typeof entries)[number], b: (typeof entries)[number]) =>
  b.id.localeCompare(a.id, undefined, { numeric: true });

const sections = {
  education: entries.filter((entry) => entry.id.startsWith("education/")).sort(sortEntries),
  work: entries.filter((entry) => entry.id.startsWith("work/")).sort(sortEntries),
  volunteer: entries.filter((entry) => entry.id.startsWith("volunteer/")).sort(sortEntries),
};
---

<BaseLayout title={frontmatter.title}>
  <div class="profile-header">
    <img src={`${import.meta.env.BASE_URL}assets/images/profile.jpg`} class="cv-profile-image" alt={`${site.author} profile photo`} />
  </div>

  <div class="cv">
    <div class="cv-heading">
      <div class="cv-heading-main">
        <h2 class="cv-close-header">{site.author}</h2>
        <h3>{frontmatter.job_title}</h3>
        <p>{frontmatter.introduction}</p>
      </div>
      <div class="cv-heading-side">
        <p><a class="inherits-color" href={`mailto:${site.email}`}>{site.email}&nbsp;&nbsp;<i class="fa fa-envelope" aria-hidden="true"></i></a></p>
        <p>{site.phone}&nbsp;&nbsp;<i class="fa-solid fa-phone" aria-hidden="true"></i></p>
        <p>{site.location}&nbsp;&nbsp;<i class="fa-solid fa-location-dot" aria-hidden="true"></i></p>
        <p><a class="inherits-color" href={site.url}>{site.domain}&nbsp;&nbsp;<i class="fa-solid fa-globe" aria-hidden="true"></i></a></p>
        {site.socials
          .filter((social) => social.name === "LinkedIn")
          .map((social) => (
            <p>
              <a class="inherits-color" href={`https://${social.url}${social.id}`}>
                {social.url}
                {social.id}
                &nbsp;&nbsp;<i class={social.icon} aria-hidden="true"></i>
              </a>
            </p>
          ))}
      </div>
    </div>
  </div>

  <div class="cv-section">
    <hr />
    <h2>Education</h2>
    {await Promise.all(
      sections.education.map(async (entry) => {
        const { Content } = await entry.render();
        return (
          <article class="cv-entry">
            <h3 class="cv-close-header">{entry.data.title}</h3>
            <p class="cv-close-header">{entry.data.location}</p>
            <sup>
              {entry.data.start_date} - {entry.data.end_date}
            </sup>
            <Content />
          </article>
        );
      }),
    )}
  </div>

  <div class="cv-section">
    <hr />
    <h2>Work Experience</h2>
    {await Promise.all(
      sections.work.map(async (entry) => {
        const { Content } = await entry.render();
        return (
          <article class="cv-entry">
            <h3 class="cv-close-header">{entry.data.title}</h3>
            <p class="cv-close-header">{entry.data.location}</p>
            <sup>
              {entry.data.start_date} - {entry.data.end_date}
            </sup>
            <Content />
          </article>
        );
      }),
    )}
  </div>

  <div class="cv-section">
    <hr />
    <h2>Volunteering</h2>
    {await Promise.all(
      sections.volunteer.map(async (entry) => {
        const { Content } = await entry.render();
        return (
          <article class="cv-entry">
            <h3 class="cv-close-header">{entry.data.title}</h3>
            <p class="cv-close-header">{entry.data.location}</p>
            <sup>
              {entry.data.start_date} - {entry.data.end_date}
            </sup>
            <Content />
          </article>
        );
      }),
    )}
  </div>

  <div class="cv-section">
    <hr />
    <h2>Programming Tools</h2>
    <div>
      {frontmatter.programming_tools.map((tool: string) => (
        <div class="cv-skill-box">{tool}</div>
      ))}
    </div>
  </div>

  <div class="cv-section">
    <hr />
    <h2>Languages</h2>
    <div class="cv-languages">
      <div>
        <p class="cv-close-header">English</p>
        <sup>Native</sup>
      </div>
      <div>
        <p class="cv-close-header">Japanese</p>
        <sup>Limited Working Proficiency</sup>
      </div>
    </div>
  </div>

  <div class="cv-section">
    <hr />
    <p>
      <i>
        I have chosen to omit references from this rendition of my curriculum vitae to ensure my references are not
        unduly contacted. I will gladly provide references to recruiters or potential employers upon request.
      </i>
    </p>
  </div>
</BaseLayout>
