---
import { getCollection } from "astro:content";
import { site } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

if (!site.features.blogEnabled) {
  return Astro.redirect(import.meta.env.BASE_URL);
}

const posts = (await getCollection("blog")).sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<BaseLayout title="Blog" description="Writing on software, generative art, and related technical interests.">
  <h1>Blog</h1>
  <p>A directory of posts written in plain markdown.</p>

  <section class="blog-directory" aria-label="Blog posts">
    {posts.length > 0 ? (
      <ol class="blog-directory-list">
        {posts.map((post) => (
          <li class="blog-directory-item">
            <a class="blog-directory-link" href={`${import.meta.env.BASE_URL}blog/${post.slug}/`}>
              {post.data.title}
            </a>
          </li>
        ))}
      </ol>
    ) : (
      <p>No blog posts published yet.</p>
    )}
  </section>
</BaseLayout>
