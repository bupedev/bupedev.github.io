---
import CvDocument from "../../../components/CvDocument.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { cvPage, getCvSections } from "../../../data/cv";

const sections = await getCvSections();
const downloadHref = `${import.meta.env.BASE_URL}generated/ben-lewis-cv.pdf`;
---

<BaseLayout title={cvPage.title}>
  <div class="cv-actions">
    <a class="cv-download-button" href={downloadHref} download>
      Download CV
    </a>
  </div>

  <CvDocument cvPage={cvPage} sections={sections} />
</BaseLayout>
