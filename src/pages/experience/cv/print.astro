---
import ExperienceDocument from "../../../components/ExperienceDocument.astro";
import PrintLayout from "../../../layouts/PrintLayout.astro";
import { getExperiencePageContent, getExperienceSections } from "../../../data/experience";

const page = getExperiencePageContent("cv");
const sections = await getExperienceSections("cv");
---

<PrintLayout title={`${page.title} Print`}>
  <ExperienceDocument exposure="cv" page={page} sections={sections} />
</PrintLayout>
