---
import { site } from "../data/site";
import ExperienceBulletList from "./ExperienceBulletList.astro";
import type { getExperiencePageContent, getExperienceSections, ExposureFlag } from "../data/experience";

interface Props {
  exposure: ExposureFlag;
  page: ReturnType<typeof getExperiencePageContent>;
  sections: Awaited<ReturnType<typeof getExperienceSections>>;
}

const { exposure, page, sections } = Astro.props;

const hasEntries = sections.education.length > 0 || sections.work.length > 0 || sections.volunteer.length > 0;
const hasSupplementaryContent =
  page.skillGroups.length > 0 || page.languages.length > 0 || page.jobTitle || page.introduction || page.closingNote;
const isEmpty = !hasEntries && !hasSupplementaryContent;
---

{!isEmpty ? (
  <>
    <div class="cv">
      <div class="cv-heading">
        <div class="cv-heading-main">
          <div class="cv-name-row">
            <h2 class="cv-close-header">{site.author}</h2>
            <div class="cv-contact-row">
              <p>
                <a class="inherits-color" href={`mailto:${site.email}`}>
                  <i class="fa fa-envelope" aria-hidden="true"></i>
                  <span>{site.email}</span>
                </a>
              </p>
              <p>
                <i class="fa-solid fa-phone" aria-hidden="true"></i>
                <span>{site.phone}</span>
              </p>
              <p>
                <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
                <span>{site.location}</span>
              </p>
            </div>
          </div>
          {page.jobTitle ? <h3>{page.jobTitle}</h3> : null}
          {page.introduction ? <p>{page.introduction}</p> : null}
        </div>
      </div>
    </div>

    {sections.education.length > 0 ? (
      <div class="cv-section">
        <hr />
        <h2>Education</h2>
        {sections.education.map((entry) => (
          <article class="cv-entry">
            <h3 class="cv-close-header">{entry.data.title}</h3>
            <p class="cv-close-header">{entry.data.location}</p>
            <sup>
              {entry.data.start_date} - {entry.data.end_date}
            </sup>
            <ExperienceBulletList bullets={entry.data.bullets} />
          </article>
        ))}
      </div>
    ) : null}

    {sections.work.length > 0 ? (
      <div class="cv-section">
        <hr />
        <h2>Work Experience</h2>
        {sections.work.map((entry) => (
          <article class="cv-entry">
            <h3 class="cv-close-header">{entry.data.title}</h3>
            <p class="cv-close-header">{entry.data.location}</p>
            <sup>
              {entry.data.start_date} - {entry.data.end_date}
            </sup>
            <ExperienceBulletList bullets={entry.data.bullets} />
          </article>
        ))}
      </div>
    ) : null}

    {sections.volunteer.length > 0 ? (
      <div class="cv-section">
        <hr />
        <h2>Volunteering</h2>
        {sections.volunteer.map((entry) => (
          <article class="cv-entry">
            <h3 class="cv-close-header">{entry.data.title}</h3>
            <p class="cv-close-header">{entry.data.location}</p>
            <sup>
              {entry.data.start_date} - {entry.data.end_date}
            </sup>
            <ExperienceBulletList bullets={entry.data.bullets} />
          </article>
        ))}
      </div>
    ) : null}

    {page.skillGroups.length > 0 ? (
      <div class="cv-section">
        <hr />
        <h2>Technical Focus</h2>
        <div class="experience-skill-groups">
          {page.skillGroups.map((group) => (
            <div class="experience-skill-group">
              <p class="experience-skill-group-title">{group.title}:</p>
              <p class="experience-skill-group-items">{group.items.join(", ")}</p>
            </div>
          ))}
        </div>
      </div>
    ) : null}

    {page.languages.length > 0 ? (
      <div class="cv-section">
        <hr />
        <h2>Languages</h2>
        <div class="cv-languages">
          {page.languages.map((language) => (
            <div>
              <p class="cv-close-header">{language.name}</p>
              <sup>{language.proficiency}</sup>
            </div>
          ))}
        </div>
      </div>
    ) : null}

    {page.closingNote ? (
      <div class="cv-section">
        <hr />
        <p>
          <i>{page.closingNote}</i>
        </p>
      </div>
    ) : null}
  </>
) : (
  <div class="experience-empty-state">
    <h1>{exposure === "cv" ? "CV" : "Resume"}</h1>
    <p>{exposure === "cv" ? "No CV content is currently available." : "Resume content is being prepared."}</p>
  </div>
)}
